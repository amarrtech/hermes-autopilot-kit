# Copy to .env and fill through the installer UI or secret manager.
# Do not commit real values.

AUTOPILOT_NAME=Hermes Autopilot
AUTOPILOT_CHANNEL=discord

MODEL_PROVIDER=openai
MODEL_NAME=gpt-5.5
MODEL_API_KEY=

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

GITHUB_BACKUP_REPO=
GITHUB_TOKEN=

BRAIN_REPO_PATH=/opt/data/brain
HERMES_DATA_PATH=/opt/data

ENABLE_GBRAIN=true
GBRAIN_HOME=/opt/data/gbrain
GBRAIN_SYNC_INTERVAL="*/5 * * * *"
ENABLE_XURL=false
ENABLE_GOOGLE_WORKSPACE=false
ENABLE_STRIPE_WATCH=false
